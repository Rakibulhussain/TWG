{
  "expo": {
    "name": "TGW",
    "slug": "TGW",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tgw",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rakibulhussain1100.TGW"
    },
    "android": {
      "package": "com.rakibulhussain1100.TGW",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2e56951f-27cf-42e8-8591-868f6ad0e959"
      }
    },
    "owner": "rakibulhussain1100",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
        "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/2e56951f-27cf-42e8-8591-868f6ad0e959"
    }
  }
}
